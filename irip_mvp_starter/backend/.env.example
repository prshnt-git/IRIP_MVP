# Copy this file to .env and fill values locally.
# Never commit your real .env file.

GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.5-flash

# off | selective | always
IRIP_LLM_MODE=selective

# gemini is the only implemented provider for nogit add .gitignore backend/.env.examplew.
IRIP_LLM_PROVIDER=gemini